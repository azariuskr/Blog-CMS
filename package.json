{
  "name": "blog-cms",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev --host 0.0.0.0 --port 3000",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "format": "biome format",
    "lint": "biome lint",
    "check": "biome check src scripts vite.config.ts",
    "ui": "pnpm dlx shadcn@latest",
    "auth:secret": "pnpm dlx @better-auth/cli@latest secret",
    "auth:generate": "pnpm dlx @better-auth/cli@latest generate --config ./src/lib/auth/auth.ts --y --output ./src/lib/db/schema/auth.schema.ts && prettier --write ./src/lib/db/schema/auth.schema.ts",
    "db": "drizzle-kit",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "seed:blog": "tsx scripts/seed-blog.ts",
    "seed:blog:no-assets": "BLOG_SEED_UPLOAD_ASSETS=false tsx scripts/seed-blog.ts",
    "ci:route-smoke": "node scripts/ci/route-smoke.mjs",
    "ci:auth-redirect": "node scripts/ci/auth-redirect-sanity.mjs",
    "ci:no-hardcoded-colors": "node scripts/ci/no-hardcoded-colors.mjs",
    "ci:blog-schema-contract": "node scripts/ci/blog-schema-contract.mjs",
    "ci:check": "pnpm build && pnpm ci:route-smoke && pnpm ci:auth-redirect && pnpm ci:no-hardcoded-colors && pnpm ci:blog-schema-contract"
  },
