NODE_ENV=development
VITE_BASE_URL=http://localhost:3000
COOKIE_PREFIX=template


ENABLE_2FA=false
VITE_ENABLE_2FA=false
ENABLE_PASSKEYS=false
VITE_ENABLE_PASSKEYS=false

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
DATABASE_URL="postgresql://postgres:password@localhost:6432/tanstack_saas?sslmode=disable&application_name=tanstack_saas&connect_timeout=10"
USE_PGBOUNCER=true

# Direct connection (simpler for debugging)
# DATABASE_URL="postgresql://postgres:password@localhost:5432/tanstack_saas?sslmode=disable"
# USE_PGBOUNCER=false

# PostgreSQL credentials
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=tanstack_saas

# Connection pool settings
DATABASE_POOL_MAX=50
DATABASE_POOL_MIN=2
DATABASE_POOL_IDLE_TIMEOUT_SEC=30
DATABASE_CONNECTION_TIMEOUT_SEC=10
DATABASE_STATEMENT_TIMEOUT_MS=30000
DATABASE_QUERY_TIMEOUT_MS=30000
DATABASE_APPLICATION_NAME=tanstack_saas

# Advanced settings
DATABASE_SSL=false
DATABASE_LOG_QUERIES=false
DATABASE_LOG_NOTICES=false
DATABASE_DEBUG=false
MONITORING_USER=monitoring
MONITORING_PASSWORD=monitoring123
# =============================================================================
# PGBOUNCER CONFIGURATION
# =============================================================================
PG_HOST=postgres                       # this should be changed if PG is changed
PG_PORT=5432                           # this should be changed if PG is changed
PGBOUNCER_POOL_MODE=transaction        # Best for REST APIs
PGBOUNCER_MAX_CLIENT_CONN=1000
PGBOUNCER_DEFAULT_POOL_SIZE=50
# =============================================================================

NODE_ENV=development
VITE_BASE_URL=http://localhost:3000

# pnpm run auth:secret
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=tanstarter-dev-secret-please-change-123456

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=




# =============================================================================
# BILLING CONFIGURATION (Better Auth Plugins)
# =============================================================================

# Billing Provider: "stripe" | "polar" | "none"
# Set to "none" to disable billing entirely
BILLING_PROVIDER=none
VITE_BILLING_PROVIDER=none

# -----------------------------------------------------------------------------
# STRIPE CONFIGURATION
# -----------------------------------------------------------------------------
# Get your keys from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs (create in Stripe Dashboard, then copy IDs here)
# Pro Plan
STRIPE_PRO_MONTHLY_PRICE_ID=price_...
STRIPE_PRO_YEARLY_PRICE_ID=price_...
# Enterprise Plan
STRIPE_ENTERPRISE_MONTHLY_PRICE_ID=price_...
STRIPE_ENTERPRISE_YEARLY_PRICE_ID=price_...

# -----------------------------------------------------------------------------
# POLAR CONFIGURATION (Alternative to Stripe)
# -----------------------------------------------------------------------------
# Get your access token from: https://polar.sh/dashboard/settings/developers
POLAR_ACCESS_TOKEN=
POLAR_WEBHOOK_SECRET=
POLAR_ORGANIZATION_ID=

# Polar Product IDs (create in Polar Dashboard)
POLAR_PRO_PRODUCT_ID=
POLAR_ENTERPRISE_PRODUCT_ID=

# Credit packages for Polar (optional, for one-time purchases)
# POLAR_CREDITS_STARTER_PRODUCT_ID=
# POLAR_CREDITS_PROFESSIONAL_PRODUCT_ID=
# POLAR_CREDITS_ENTERPRISE_PRODUCT_ID=

# -----------------------------------------------------------------------------
# BILLING SETTINGS
# -----------------------------------------------------------------------------
BILLING_TRIAL_DAYS=14
BILLING_GRACE_PERIOD_DAYS=3
BILLING_DEFAULT_CURRENCY=usd




# Email Configuration (MailHog for development)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@tanstarter.local
EMAIL_FROM_NAME=TanStack SaaS Template
# =============================================================================
# REDIS CONFIGURATION - From Docker Compose
# =============================================================================

# Single Redis instance (no Sentinel)
REDIS_URL=redis://:SecureRedis123!@localhost:6379/0
REDIS_PASSWORD=SecureRedis123!
REDIS_DB=0
REDIS_HOST=localhost
REDIS_PORT=6379

# Redis Connection Pool (for ioredis)
REDIS_MAX_RETRIES=3
REDIS_CONNECT_TIMEOUT=10000
REDIS_COMMAND_TIMEOUT=5000
REDIS_KEEP_ALIVE=30000
REDIS_ENABLE_READY_CHECK=true
REDIS_ENABLE_OFFLINE_QUEUE=true

# =============================================================================
# FILE STORAGE CONFIGURATION
# =============================================================================

# Storage Provider: "local" | "minio" | "r2"
# - local: Uses local filesystem (default, no external dependencies)
# - minio: Uses MinIO S3-compatible storage (good for development/self-hosted)
# - r2: Uses Cloudflare R2 (good for production)
STORAGE_PROVIDER=minio

# Local Storage (default - no external dependencies needed)
LOCAL_STORAGE_PATH=./storage
LOCAL_STORAGE_URL_PREFIX=/api/storage/files

# MinIO (Local Development - Started via Docker Compose)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_USE_SSL=false
MINIO_BUCKET_NAME=tanstack-files
MINIO_REGION=us-east-1

# Cloudflare R2 (Production)
CLOUDFLARE_R2_ACCESS_KEY_ID=...
CLOUDFLARE_R2_SECRET_ACCESS_KEY=...
R2_BUCKET_NAME=tanstack-saas-files
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_PUBLIC_URL=https://files.yourapp.com

# File Processing
VITE_MAX_FILE_SIZE_MB=100
MAX_FILE_SIZE_MB=100
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,image/webp,application/pdf,text/plain,text/csv
IMAGE_QUALITY=85
IMAGE_THUMBNAIL_SIZE=300
VIDEO_MAX_DURATION_SECONDS=3600


# =============================================================================
# INNGEST BACKGROUND JOB PROCESSING
# =============================================================================

INNGEST_EVENT_KEY=inngest-event-key-dev
INNGEST_HASH_KEY=inngest-hash-key-dev
INNGEST_SIGNING_KEY=signkey-dev
INNGEST_JWT_SECRET=inngest-jwt-secret-dev
INNGEST_BASE_URL=http://localhost:8288
INNGEST_APP_URL=http://localhost:3000
INNGEST_DEV=1
